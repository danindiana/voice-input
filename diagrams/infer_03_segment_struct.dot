
digraph {
    bgcolor="#0a0a1a" fontname="monospace" fontcolor="#e0e0e0"
    node [fontname="monospace" fontsize=10 style=filled penwidth=2]
    edge [fontname="monospace" fontsize=9 penwidth=1.5]

    seg  [label="Segment
────────────────
.start  float
.end    float
.text   str
.words  list[Word]" shape=record fillcolor="#0a001a" color="#ff00ff" fontcolor="#ff00ff"]
    word [label="Word
────────────────
.start       float
.end         float
.word        str
.probability float (0-1)" shape=record fillcolor="#001520" color="#00ffff" fontcolor="#00ffff"]

    prob_hi  [label="prob ≥ 0.92
→ bright white" shape=box fillcolor="#001a00" color="#39ff14" fontcolor="#39ff14"]
    prob_mid [label="0.75 ≤ prob < 0.92
→ normal" shape=box fillcolor="#0d0d0d" color="#e0e0e0" fontcolor="#e0e0e0"]
    prob_unc [label="0.50 ≤ prob < 0.75
→ yellow" shape=box fillcolor="#1a1a00" color="#ffff00" fontcolor="#ffff00"]
    prob_lo  [label="prob < 0.50
→ red" shape=box fillcolor="#1a0000" color="#ff2244" fontcolor="#ff2244"]

    seg -> word    [label="1:N" color="#ff00ff"]
    word -> prob_hi [label=".probability" color="#39ff14"]
    word -> prob_mid [color="#e0e0e0"]
    word -> prob_unc [color="#ffff00"]
    word -> prob_lo  [color="#ff2244"]
}
