
digraph {
    bgcolor="#111827" fontname="monospace" fontcolor="#e0e0e0"
    node [fontname="monospace" fontsize=10 style=filled penwidth=2]
    edge [fontname="monospace" fontsize=9 penwidth=1.5]

    enter  [label="User presses Enter
(read < /dev/tty)" shape=parallelogram fillcolor="#001520" color="#00ffff" fontcolor="#00ffff"]
    timer  [label="65s timer fires
(background subshell)" shape=box fillcolor="#1a0a00" color="#ff6600" fontcolor="#ff6600"]

    kill_p [label="kill PAREC_PID" shape=box fillcolor="#0d0d0d" color="#ff2244" fontcolor="#ff2244"]
    usr1   [label="kill -USR1 MAIN_PID" shape=box fillcolor="#0d0d0d" color="#ff2244" fontcolor="#ff2244"]
    trap   [label="trap 'true' USR1
(interrupts read)" shape=box fillcolor="#001a00" color="#39ff14" fontcolor="#39ff14"]

    read_unblock [label="read unblocked" shape=diamond fillcolor="#0d0d0d" color="#ffff00" fontcolor="#ffff00"]
    kill_t [label="kill TIMER_PID
kill PAREC_PID
wait PAREC_PID" shape=box fillcolor="#001520" color="#00ffff" fontcolor="#00ffff"]
    cont   [label="Continue to sox + transcribe" shape=oval fillcolor="#001500" color="#ccff00" fontcolor="#ccff00"]

    enter -> read_unblock [color="#00ffff" label="direct"]
    timer -> kill_p       [color="#ff6600"]
    timer -> usr1         [color="#ff6600"]
    usr1  -> trap         [color="#ff2244"]
    trap  -> read_unblock [color="#39ff14" label="via signal"]
    read_unblock -> kill_t [color="#ffff00"]
    kill_t -> cont         [color="#ccff00"]
}
