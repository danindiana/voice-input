
digraph {
    bgcolor="#080818" fontname="monospace" fontcolor="#e0e0e0"
    node [fontname="monospace" fontsize=10 style=filled penwidth=2 shape=box]
    edge [fontname="monospace" fontsize=9 penwidth=1.5]

    inv   [label="transcribe.py invoked" fillcolor="#001520" color="#00ffff" fontcolor="#00ffff"]
    cache [label="~/.cache/huggingface/
hub/models--Systran--
faster-whisper-medium
(~1.5 GB)" shape=cylinder fillcolor="#0a001a" color="#ff00ff" fontcolor="#ff00ff"]
    chk   [label="Already cached?" shape=diamond fillcolor="#0d0d0d" color="#ffff00" fontcolor="#ffff00"]
    dl    [label="Download from
HuggingFace Hub
(first run only)" fillcolor="#1a0a00" color="#ff6600" fontcolor="#ff6600"]
    vram  [label="Load into VRAM
float16
~1.5GB" fillcolor="#1a0000" color="#ff2244" fontcolor="#ff2244"]
    ready [label="Model ready
→ transcribe()" fillcolor="#001500" color="#39ff14" fontcolor="#39ff14"]

    inv -> chk    [color="#00ffff"]
    chk -> dl     [label="no" color="#ff6600"]
    chk -> vram   [label="yes" color="#39ff14"]
    dl  -> cache  [label="save" color="#ff6600"]
    cache -> vram [color="#ff2244"]
    vram -> ready [color="#39ff14"]
}
