
digraph {
    bgcolor="#111827" fontname="monospace" fontcolor="#e0e0e0"
    node [fontname="monospace" fontsize=10 style=filled penwidth=2]
    edge [fontname="monospace" fontsize=9 penwidth=1.5]
    rankdir=TB

    subgraph cluster_capture {
        bgcolor="#0a0a0a" color="#00ffff" label="Audio Capture" fontcolor="#00ffff" penwidth=2
        mic  [label="Mic Input
32kHz mono" shape=parallelogram fillcolor="#0d1b2a" color="#00ffff" fontcolor="#00ffff"]
        raw  [label="/tmp/voice-*.raw
raw s16le PCM" shape=cylinder fillcolor="#0d1b2a" color="#00ffff" fontcolor="#00ffcc"]
        wav  [label="/tmp/voice-*.wav
standard WAV" shape=cylinder fillcolor="#0d1b2a" color="#00ffff" fontcolor="#00ffcc"]
    }

    subgraph cluster_infer {
        bgcolor="#0a0a0a" color="#ff00ff" label="Inference" fontcolor="#ff00ff" penwidth=2
        model [label="faster-whisper
medium float16" shape=box fillcolor="#1a001a" color="#ff00ff" fontcolor="#ff00ff"]
        segs  [label="Segments +
Word timestamps" shape=note fillcolor="#1a001a" color="#ff00ff" fontcolor="#ff1493"]
    }

    subgraph cluster_out {
        bgcolor="#0a0a0a" color="#39ff14" label="Output" fontcolor="#39ff14" penwidth=2
        text  [label="Plain text" shape=box fillcolor="#001a00" color="#39ff14" fontcolor="#39ff14"]
        anim  [label="Animated
terminal render" shape=box fillcolor="#001a00" color="#39ff14" fontcolor="#ccff00"]
    }

    mic -> raw  [label="parec" color="#00ffff"]
    raw -> wav  [label="sox" color="#00ffff"]
    wav -> model [label="transcribe.py" color="#ff00ff"]
    model -> segs [color="#ff00ff"]
    segs -> text [label="--no-fancy" color="#39ff14"]
    segs -> anim [label="--fancy" color="#ccff00"]
}
