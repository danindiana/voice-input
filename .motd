#!/usr/bin/env bash
# .motd вҖ” displayed automatically when you cd into this directory
# (wired via chpwd hook in ~/.zshrc)

B='\033[1m'; C='\033[0;36m'; G='\033[0;32m'
Y='\033[1;33m'; R='\033[0;31m'; D='\033[2m'; Z='\033[0m'
BC='\033[1;36m'; BY='\033[1;33m'; BG='\033[1;32m'

# в”Җв”Җ banner в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo ""
echo -e "${BC}в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${Z}"
echo -e "${BC}в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ${Z}"
echo -e "${BC}в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—  ${Z}"
echo -e "${BC}в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в–Ҳв–Ҳв•”в•җв•җв•қ  ${Z}"
echo -e "${BC} в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${Z}"
echo -e "${BC}  в•ҡв•җв•җв•җв•қ   в•ҡв•җв•җв•җв•җв•җв•қ в•ҡв•җв•қ в•ҡв•җв•җв•җв•җв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ${Z}"
echo -e "${BY}в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—${Z}"
echo -e "${BY}в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв•—  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в•ҡв•җв•җв–Ҳв–Ҳв•”в•җв•җв•қ${Z}"
echo -e "${BY}в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в–Ҳв–Ҳв•— в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   ${Z}"
echo -e "${BY}в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•қ в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘   ${Z}"
echo -e "${BY}в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘     в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ   в–Ҳв–Ҳв•‘   ${Z}"
echo -e "${BY}в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•җв•җв•қв•ҡв•җв•қ      в•ҡв•җв•җв•җв•җв•җв•қ   в•ҡв•җв•қ   ${Z}"
echo -e "${D}  speak  в–ё  whisper.cpp + cuda  в–ё  type  В·  pure rust В· no python${Z}"
echo ""

# в”Җв”Җ git info в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "  ${D}$(git -C "$(dirname "${BASH_SOURCE[0]}")" log -1 --format='branch: %D  В·  last commit: %h %s' 2>/dev/null)${Z}"
echo ""

# в”Җв”Җ binary health в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
for bin in voice-input voice-ambient voice-wizard; do
    path=$(command -v "$bin" 2>/dev/null)
    if [[ -n "$path" && -x "$path" ]]; then
        real=$(readlink -f "$path" 2>/dev/null)
        echo -e "  ${BG}[OK]${Z}  ${B}${bin}${Z}  ${D}вҶ’ ${real}${Z}"
    else
        echo -e "  ${R}[!!]${Z}  ${B}${bin}${Z}  ${Y}not in PATH вҖ” rebuild? cargo build --release${Z}"
    fi
done

echo ""

# в”Җв”Җ whisper model в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
MODEL="$HOME/.cache/whisper/ggml-large-v3.bin"
if [[ -f "$MODEL" ]]; then
    SIZE=$(du -sh "$MODEL" 2>/dev/null | awk '{print $1}')
    echo -e "  ${BG}[OK]${Z}  ${B}ggml-large-v3.bin${Z}  ${D}${SIZE}  ${MODEL}${Z}"
else
    echo -e "  ${R}[!!]${Z}  ${B}ggml-large-v3.bin${Z}  ${Y}missing вҖ” transcription will fail${Z}"
    echo -e "        ${D}expected: ${MODEL}${Z}"
fi

# в”Җв”Җ UC03 mic в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
MIC="alsa_input.usb-UC03_UC03-00.mono-fallback"
if pactl list sources short 2>/dev/null | grep -q "$MIC"; then
    echo -e "  ${BG}[OK]${Z}  ${B}UC03 mic${Z}  ${D}PipeWire source present${Z}"
else
    echo -e "  ${Y}[--]${Z}  ${B}UC03 mic${Z}  ${D}not detected (headset unplugged?)${Z}"
fi

echo ""

# в”Җв”Җ quick reference в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
echo -e "  ${B}Quick start:${Z}"
echo -e "    ${C}voice-wizard${Z}               ${D}вҶҗ start here if you're new${Z}"
echo -e "    ${C}voice-input --mode type${Z}    ${D}speak вҶ’ typed into active window${Z}"
echo -e "    ${C}voice-input --mode clip${Z}    ${D}speak вҶ’ clipboard${Z}"
echo -e "    ${C}voice-input --mode print${Z}   ${D}speak вҶ’ stdout${Z}"
echo -e "    ${C}voice-input --mode ambient${Z} ${D}speak вҶ’ continuous TUI + SQLite log${Z}"
echo ""
echo -e "  ${D}Rebuild:  cd voice-ambient && cargo build --release${Z}"
echo ""
