
digraph {
    bgcolor="#0f0f0f" fontname="monospace" fontcolor="#e0e0e0"
    node [fontname="monospace" fontsize=10 style=filled penwidth=2 shape=box]
    edge [fontname="monospace" fontsize=9 penwidth=1.5]

    load  [label="WhisperModel('medium',
  device='cuda',
  compute_type='float16')
→ loads to VRAM once" fillcolor="#0a001a" color="#ff00ff" fontcolor="#ff00ff"]
    call  [label="model.transcribe(
  wav_path,
  beam_size=5,
  language='en',
  word_timestamps=True
)" fillcolor="#001520" color="#00ffff" fontcolor="#00ffff"]
    gen   [label="generator yields
Segment objects
(streaming — not buffered)" fillcolor="#001a00" color="#39ff14" fontcolor="#39ff14"]
    loop  [label="for segment in segments:
  for word in segment.words:" fillcolor="#001500" color="#ccff00" fontcolor="#ccff00"]
    out   [label="animate_word()
or print()" fillcolor="#1a001a" color="#ff1493" fontcolor="#ff1493"]

    load -> call [label="call transcribe()" color="#00ffff"]
    call -> gen  [label="returns generator" color="#39ff14"]
    gen  -> loop [label="iterate" color="#ccff00"]
    loop -> out  [color="#ff1493"]
}
